# core/flyvis_env.py
import gym
from gym import spaces
import numpy as np

class FlyvisEnv(gym.Env):
    metadata = {'render.modes': ['human']}

    def __init__(self):
        super(FlyvisEnv, self).__init__()
        # 定义动作空间和观察空间
        self.action_space = spaces.Discrete(4)  # 示例：4个动作
        self.observation_space = spaces.Box(low=-1, high=1, shape=(10,), dtype=np.float32)

    def reset(self):
        # 重置环境
        return np.random.randn(10).astype(np.float32)

    def step(self, action):
        # 执行动作，返回新状态、奖励、是否结束等
        obs = np.random.randn(10).astype(np.float32)
        reward = 1.0
        done = False
        info = {}
        return obs, reward, done, info

    def render(self, mode='human'):
        pass